# ═══════════════════════════════════════════
#  图灵绘境 — 环境变量配置示例
#  复制此文件为 .env 并填入真实值
# ═══════════════════════════════════════════

# ── 服务器 ──
PORT=3000
NODE_ENV=development

# ── JWT 密钥（必填，用于用户登录鉴权）──
JWT_SECRET=your_jwt_secret_here

# ── 智谱 GLM-Image 生图 API ──
# 获取地址: https://open.bigmodel.cn/usercenter/apidocs
ZHIPU_API_KEY=your_zhipu_api_key_here
# 模型选择: glm-image(推荐) / cogview-4 / cogview-3-flash
ZHIPU_MODEL=glm-image
# 是否开启广告墙（true/false）
ZHIPU_ENABLE_AD_GATE=true
# 每日免费生成次数（需登录）
ZHIPU_DAILY_FREE_LIMIT=3
# 每次生图成本（元），用于统计
ZHIPU_COST_PER_GEN=0.1

# ── 微信小程序激励视频广告 ID ──
# 在微信公众平台 → 流量主 → 广告位管理 中获取
WX_AD_UNIT_ID=

# ── AI 分析服务（OpenRouter，用于图片分析）──
# 获取地址: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── 数据库目录（可选，默认 ./data）──
# DATA_DIR=/data/vol01/turing
