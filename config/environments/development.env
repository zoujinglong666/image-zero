# ══════════════════════════════════════════
# 图灵绘境开发环境配置
# ══════════════════════════════════════════

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=turing_drawing_dev
DB_USERNAME=root
DB_PASSWORD=dev_password

# JWT配置
JWT_SECRET=dev_jwt_secret_key_please_change_in_production

# 腾讯云COS配置（开发环境可留空）
COS_SECRET_ID=
COS_SECRET_KEY=
COS_REGION=ap-guangzhou
COS_BUCKET=
COS_DOMAIN=

# AI服务配置（开发环境可留空或使用测试key）
OPENAI_API_KEY=
GEMINI_API_KEY=

# 微信配置（开发环境可留空）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# CORS配置（开发环境允许本地访问）
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# 其他配置
SPRING_PROFILES_ACTIVE=dev
NGINX_CONF=./deploy/nginx-no-domain.conf