# ══════════════════════════════════════════
# 图灵绘境后端环境变量配置
# 复制此文件为 .env 并修改对应的值
# ══════════════════════════════════════════

# 运行环境 (development / production)
NODE_ENV=development

# 服务端口
PORT=3000

# OpenRouter API Key (必填)
# 免费申请: https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_api_key_here

# 分析模型（可选，默认使用免费模型）
ANALYSIS_MODEL=nvidia/nemotron-nano-12b-v2-vl:free

# CORS 允许的域名（多个用逗号分隔，不要有空格）
# ⚠️ 生产环境必须修改此配置！不能包含 localhost
ALLOWED_ORIGINS=https://www.image-zero.art,http://localhost:5173,http://localhost:3000

# JWT 认证密钥（生产环境必填！）
# 生成方式: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=

# JWT 令牌有效期
JWT_EXPIRES_IN=7d

# 上传文件大小限制（单位: MB）
MAX_FILE_SIZE=10

# 速率限制配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# 日志级别 (debug / info / warn / error)
LOG_LEVEL=info

# 日志输出目录
LOG_DIR=logs/

# ══════════════════════════════════════════
# 微信小程序配置（可选，用于微信登录）
# ══════════════════════════════════════════
# 小程序 AppID（微信公众平台 → 开发管理 → 开发设置）
WX_APPID=
# 小程序 AppSecret
WX_SECRET=

# ══════════════════════════════════════════
# 数据库目录（Railway Volume 挂载路径）
# ══════════════════════════════════════════
# DATA_DIR=/data

# ══════════════════════════════════════════
# 腾讯云 COS 对象存储（社区图片上传）
# 控制台: https://console.cloud.tencent.com/cos5/bucket
# ══════════════════════════════════════════
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=your-bucket-1234567890        # 格式: bucket名-APPID
COS_REGION=ap-guangzhou                   # 地域: ap-guangzhou / ap-shanghai / ap-beijing
COS_DOMAIN=                               # 可选: 自定义 CDN 域名(留空则用 COS 默认域名)