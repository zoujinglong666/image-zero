# ══════════════════════════════════════════
#  图灵绘境 - 后端环境变量示例（复制为 .env 并填写）
# ══════════════════════════════════════════

# ━━━ MySQL 数据库 ━━━
DB_HOST=localhost
DB_PORT=3306
DB_NAME=turing_drawing
DB_USERNAME=root
DB_PASSWORD=

# ━━━ 智谱 AI（图片分析，GLM-4.6V-Flash 免费）━━━
# 注册: https://open.bigmodel.cn/ 获取 API Key
ZHIPU_API_KEY=your_zhipu_api_key_here

# ━━━ OpenAI / OpenRouter（可选，图片分析备用）━━━
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# ━━━ AI 模型配置 ━━━
AI_ANALYZE_MODEL=glm-4.6v-flash
AI_GENERATE_MODEL=dall-e-3

# ━━━ JWT 认证 ━━━
JWT_SECRET=your-jwt-secret-min-32-chars

# ━━━ 腾讯云 COS 对象存储 ━━━
COS_SECRET_ID=
COS_SECRET_KEY=
COS_BUCKET=
COS_REGION=ap-guangzhou
COS_DOMAIN=

# ━━━ 微信小程序 ━━━
# WECHAT_APP_ID=
# WECHAT_APP_SECRET=
# WECHAT_MINI_PROGRAM_APP_ID=
# WECHAT_MINI_PROGRAM_APP_SECRET=

# ━━━ CORS 跨域 ━━━
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ━━━ 频率限制 ━━━
RATE_LIMIT_AI=10
RATE_LIMIT_AUTH=20
RATE_LIMIT_COMMUNITY=60
RATE_LIMIT_UPLOAD=15
