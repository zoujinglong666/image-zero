{
  "pages": [
    {
      "path": "pages/index/index",
      "style": {
        "navigationBarTitleText": "图灵绘境",
        "navigationStyle": "custom",
        "enableShareAppMessage": true,
        "enableShareTimeline": true,
        "enablePullDownRefresh": true,
        "backgroundTextStyle": "dark"
      }
    },
    {
      "path": "pages/prompt/prompt",
      "style": {
        "navigationBarTitleText": "提示词库",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/edit/edit",
      "style": {
        "navigationBarTitleText": "智能编辑",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/history/history",
      "style": {
        "navigationBarTitleText": "历史记录",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/mine/mine",
      "style": {
        "navigationBarTitleText": "我的",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/publish/publish",
      "style": {
        "navigationBarTitleText": "分享到社区",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/vip/vip",
      "style": {
        "navigationBarTitleText": "VIP 会员",
        "navigationStyle": "custom"
      }
    },
    {
      "path": "pages/invite/invite",
      "style": {
        "navigationBarTitleText": "邀请好友",
        "navigationStyle": "custom"
      }
    }
  ],
  "globalStyle": {
    "backgroundColor": "@bgColor",
    "backgroundColorBottom": "@bgColorBottom",
    "backgroundColorTop": "@bgColorTop",
    "backgroundTextStyle": "@bgTxtStyle",
    "navigationBarBackgroundColor": "#7C4DFF",
    "navigationBarTextStyle": "@navTxtStyle",
    "navigationBarTitleText": "图灵绘境",
    "navigationStyle": "custom"
  },
  "tabBar": {
    "color": "@tabFontColor",
    "selectedColor": "@tabSelectedColor",
    "backgroundColor": "@tabBgColor",
    "borderStyle": "@tabBorderStyle",
    "list": [
      {
        "pagePath": "pages/index/index",
        "text": "首页",
        "iconPath": "static/tabbar/home.png",
        "selectedIconPath": "static/tabbar/home-active.png"
      },
      {
        "pagePath": "pages/prompt/prompt",
        "text": "词库",
        "iconPath": "static/tabbar/prompt.png",
        "selectedIconPath": "static/tabbar/prompt-active.png"
      },
      {
        "pagePath": "pages/history/history",
        "text": "历史",
        "iconPath": "static/tabbar/history.png",
        "selectedIconPath": "static/tabbar/history-active.png"
      },
      {
        "pagePath": "pages/mine/mine",
        "text": "我的",
        "iconPath": "static/tabbar/mine.png",
        "selectedIconPath": "static/tabbar/mine-active.png"
      }
    ]
  },
  "easycom": {
    "autoscan": true
  },
  "subPackages": [
    {
      "root": "pages/about",
      "pages": [
        {
          "path": "settings",
          "style": {
            "navigationBarTitleText": "设置",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "faq",
          "style": {
            "navigationBarTitleText": "常见问题",
            "navigationStyle": "custom"
          }
        },
        {
          "path": "guide",
          "style": {
            "navigationBarTitleText": "使用指南",
            "navigationStyle": "custom"
          }
        }
      ]
    },
    {
      "root": "pages/notification",
      "pages": [
        {
          "path": "notification",
          "style": {
            "navigationBarTitleText": "消息通知",
            "navigationStyle": "custom"
          }
        }
      ]
    }
  ]
}